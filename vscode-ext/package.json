{
  "name": "remote-clauding",
  "displayName": "Remote Clauding",
  "description": "Share Claude Code sessions to your mobile phone",
  "version": "0.7.0",
  "publisher": "remote-clauding",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "remote-clauding-panel",
          "title": "Remote Clauding",
          "icon": "media/icon.svg",
          "when": "remote-clauding:doesNotSupportSecondarySidebar"
        }
      ],
      "secondarySidebar": [
        {
          "id": "remote-clauding-panel-secondary",
          "title": "Remote Clauding",
          "icon": "media/icon.svg",
          "when": "!remote-clauding:doesNotSupportSecondarySidebar"
        }
      ]
    },
    "views": {
      "remote-clauding-panel": [
        {
          "type": "webview",
          "id": "remote-clauding.chatView",
          "name": "Chat",
          "when": "remote-clauding:doesNotSupportSecondarySidebar"
        }
      ],
      "remote-clauding-panel-secondary": [
        {
          "type": "webview",
          "id": "remote-clauding.chatViewSecondary",
          "name": "Chat",
          "when": "!remote-clauding:doesNotSupportSecondarySidebar"
        }
      ]
    },
    "commands": [
      {
        "command": "remote-clauding.toggleShare",
        "title": "Remote Clauding: Toggle Share to Mobile"
      },
      {
        "command": "remote-clauding.openPanel",
        "title": "Remote Clauding",
        "icon": {
          "light": "media/icon.svg",
          "dark": "media/icon.svg"
        }
      },
      {
        "command": "remote-clauding.newChat",
        "title": "Remote Clauding: New Chat"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "remote-clauding.openPanel",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "package": "npx @vscode/vsce package --allow-missing-repository",
    "install-ext": "npx @vscode/vsce package --allow-missing-repository && code --install-extension remote-clauding-0.7.0.vsix --force && rm remote-clauding-0.7.0.vsix"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "qrcode": "^1.5.4"
  }
}
